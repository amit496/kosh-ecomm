# WordPress core files
# wp-admin/
# wp-includes/
# readme.html
# license.txt

# Logs and databases
*.log
*.sql
*.sqlite

# OS generated files
.DS_Store
Thumbs.db

# PHPStorm / JetBrains
.idea/

# Composer vendor directory
vendor/

# Dependency directories
node_modules/

# Uploads and generated files
# wp-content/uploads/
# wp-content/upgrade/
wp-content/plugins/*/node_modules/
wp-content/themes/*/node_modules/

# Local configuration and sensitive files
# wp-config.php
.env

# Backup and temporary files
*.bak
*.tmp
*.swp
*~

# Ignore compiled assets
# *.css.map
# *.js.map
